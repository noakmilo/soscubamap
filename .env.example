SECRET_KEY=dev-change-me
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/soscubamap

# Administrador
ADMIN_EMAIL=admin@soscuba.local
ADMIN_PASSWORD=

# Imágenes (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
IMAGE_MAX_MB=2
IMAGE_MAX_PER_SUBMIT=3
IMAGE_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,heic

# Mapas (Google Maps — opcional, sin estas variables se usa Leaflet/OSM)
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=

# GeoJSON (datos geográficos — opcional)
GEOJSON_PROVINCES_PATH=
GEOJSON_MUNICIPALITIES_PATH=
GEOJSON_LOCALITIES_PATH=
GEOJSON_PROVINCE_KEYS=
GEOJSON_MUNICIPALITY_KEYS=
GEOJSON_MUNICIPALITY_PROVINCE_KEYS=
GEOJSON_LOCALITY_KEYS=
GEOJSON_LOCALITY_MUNICIPALITY_KEYS=
GEOJSON_LOCALITY_PROVINCE_KEYS=

# Push notifications — VAPID (opcional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soscubamap@proton.me

# reCAPTCHA v2 (opcional)
RECAPTCHA_V2_SITE_KEY=
RECAPTCHA_V2_SECRET_KEY=

# Rate limiting (en producción con múltiples workers usar redis://localhost:6379/0)
RATELIMIT_STORAGE_URL=memory://

# Conectividad (Cloudflare Radar — opcional)
CF_API_TOKEN=
CLOUDFLARE_RADAR_HTTP_TIMESERIES_URL=https://api.cloudflare.com/client/v4/radar/http/timeseries?name=main&name=previous&geoId=3556965&geoId=3556965&dateRange=1d&dateRange=1dControl
CF_RADAR_PROVINCE_GEOIDS_JSON=
CONNECTIVITY_FETCH_DELAY_SECONDS=120
CONNECTIVITY_FETCH_TIMEOUT_SECONDS=30
CONNECTIVITY_STALE_AFTER_HOURS=8
CONNECTIVITY_FRONTEND_REFRESH_SECONDS=300

# Protestas — layer RSS/NLP (opcional, activar poniendo feeds)
PROTEST_RSS_FEEDS=
PROTEST_FETCH_TIMEOUT_SECONDS=30
PROTEST_FRONTEND_REFRESH_SECONDS=300
PROTEST_MIN_CONFIDENCE_TO_SHOW=35
PROTEST_REQUIRE_SOURCE_URL=1
PROTEST_ALLOW_UNRESOLVED_TO_MAP=0
PROTEST_MAX_ITEMS_PER_FEED=120
PROTEST_MAX_POST_AGE_DAYS=30
PROTEST_KEYWORDS_STRONG=
PROTEST_KEYWORDS_CONTEXT=
PROTEST_KEYWORDS_WEAK=
PROTEST_PLACE_ALIASES_JSON=
PROTEST_SOURCE_NAME_OVERRIDES_JSON=

# Aplicación
CHAT_DISABLED=0
ASSET_VERSION=1
TRUST_PROXY_HEADERS=1
